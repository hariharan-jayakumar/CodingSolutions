public class Solution
{
    public static void Main()
    {
        TrieConstructor ipMatch = new TrieConstructor();
        // ipMatch.AddCidrBlock("10.0.0.0/8","a.com"],["10.1.0.0/16","b.com"],["10.1.2.0/24","c.com");
        // 
        ipMatch.AddCidrBlock("10.0.0.0/8","a.com");
        ipMatch.AddCidrBlock("10.1.0.0/16","b.com");
        ipMatch.AddCidrBlock("10.1.2.0/24","c.com");
        
        //["10.1.2.7","10.2.3.4","192.168.1.1"]
        ipMatch.GetWebsite("10.1.2.7");
        ipMatch.GetWebsite("10.2.3.4");
        ipMatch.GetWebsite("192.168.1.1");
    }
}
