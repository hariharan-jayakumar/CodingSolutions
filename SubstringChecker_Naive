public class SubstringChecker
{
    public static bool IsSubstringOf(string pattern, string text)
    {
        int textLen = text.Length;
        int patternLen = pattern.Length;

        for(int i=0;i<textLen;i++)
        {
            int k = i;
            int j = 0;
            while(j<patternLen && k < textLen && pattern[j]==text[k])
            {
                j++;
                k++;
            }
            if(j==patternLen)
            {
                return true;
            }
        }
        return false;
    }

}

public class LineFinder
{

    public List<string> Grep(List<string> text, string pattern, int lookback)
    {
        List<string> matchedLines = new();
        SortedSet<int> matchedIndices = new();

        for(int i=0;i<text.Count;i++)
        {
            if(SubstringChecker.IsSubstringOf(pattern, text[i]))
            {
                Console.WriteLine(i);
                for(int j=i-lookback;j<=i+lookback && j<text.Count;j++)
                {
                    if(j<0) continue;
                    if(!matchedIndices.Contains(j))
                    {
                        matchedIndices.Add(j);
                        matchedLines.Add(text[j]);
                    }
                }
            }
        }

        return matchedLines;
    }
}

