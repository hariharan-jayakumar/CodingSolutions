using System.Collections.Generic;

// 10 32
class WikiParser
{
    public int GetShortestPathLength(string sourceUri, string destUri)
    {
        int shortest = -1;

        Queue<(string,int)> visitedUris = new();
        visitedUris.Enqueue((sourceUri,0));
        HashSet<string> pastUris = new();
        pastUris.Add(sourceUri);

        while(visitedUris.Count>0)
        {
            (string currUri, int currLength) = visitedUris.Dequeue();
            if(currUri==destUri)
            {
                return currLength;
            }

            List<string> getLinkedUris = new();
            // getLinkedUris = getLinkedUris(); assume this will be a network call somewhere
            foreach(string nextUri in getLinkedUris)
            {
                if(!pastUris.Contains(nextUri))
                {
                    pastUris.Add(nextUri);
                    visitedUris.Enqueue((nextUri, currLength+1));
                }
            }
        }

        return shortest;
    }
}
