class Solution2
{
    // 6 26
    List<int>[] adjList = new List<int>[10];
    int availableColors = 3;
    int[] colors = new int[10];

    public void ColorNodes(int nodeId)
    {
        List<int> avlColors = new();
        for(int i=1;i<=3;i++)
        {
            avlColors.Add(i);
        }
        List<int> neighbors = this.adjList[nodeId];
        foreach(int neighbor in neighbors)
        {
            if (colors[neighbor]!=0)
            {
                avlColors.Remove(colors[neighbor]);
            }
        }

        foreach(int color in avlColors)
        {
            colors[nodeId] = color;

            colors[nodeId] = 0; //back-track
        }
    }
    // 6 33

    public TreeNode RecursivelyComputeLastTree(TreeNode node, TreeNode lastNode)
    {
        if(node == null) return lastNode;
        int value = node.val;

        if(node.left!=null) value += node.left.val;
        if(node.right!=null) value += node.right.val;

        if(lastNode == null)
        {
            return new TreeNode(value);
        }
        else
        {
            lastNode.val += value;
            lastNode.left = RecursivelyComputeLastTree(node.left, lastNode.left);
            lastNode.right = RecursivelyComputeLastTree(node.right, lastNode.right);  
        }
        return lastNode;
    }
    // 7 17
}


public class TreeNode
{
    public int val;
    public TreeNode left;
    public TreeNode right;

    public TreeNode(int val = 0, TreeNode left = null, TreeNode right = null)
    {
        this.val = val;
        this.left = left;
        this.right = right;
    }
}

public class Solution
{
    public TreeNode ConvertSumTreeMultiple(List<TreeNode> trees)
    {
        int n = trees.Count;
        for(int i=0;i<n-1;i++)
        {
            trees[n-1] = new Solution2().RecursivelyComputeLastTree(trees[i], trees[n-1]);
        }

        return trees[trees.Count - 1];
    }
}

