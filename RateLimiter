public interface IRule
{
    public bool AllowRequest(int currTimestamp);
}

public class Rule: IRule
{
    LinkedList<int> queuedRequests = new LinkedList<int>();
    public int ttl;
    public int capacity;

    public Rule(int ttl, int limit)
    {
        this.ttl = ttl;
        this.capacity = limit;
    }

    public bool AllowRequest(int currTimestamp)
    {
        RemoveExpiredRequests(currTimestamp);
        if(queuedRequests.Count < capacity)
        {
            return true;
        }
        return false;
    }

    public void AddToAllowedRequests(int currTimestamp)
    {
        Console.WriteLine($"Added {currTimestamp}");
        queuedRequests.AddLast(currTimestamp);
    }

    private void RemoveExpiredRequests(int currTimestamp)
    {
        while(queuedRequests.Count > 0 && currTimestamp - queuedRequests.First.Value >= ttl)
        {
            queuedRequests.RemoveFirst();
        }
    }
}

// 8 10
public class MultiRuleRateLimiter
{
    List<IRule> rules = new List<IRule>();

    public MultiRuleRateLimiter()
    {

    }

    public void RegisterRule(int ttl, int limit)
    {
        rules.Add(new Rule(ttl, limit));
    }

    public bool AllowRequest(int currTimestamp)
    {
        foreach(Rule rule in rules)
        {
            if (rule.AllowRequest(currTimestamp) == false)
            {
                return false;
            }
        }
        
        foreach(Rule rule in rules)
        {
            rule.AddToAllowedRequests(currTimestamp);
        }

        return true;
    }
}
